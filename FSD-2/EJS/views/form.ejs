
<h1>Enter Marks for 4 Tests</h1>
<form action="/submit" method="POST">
    <label for="t1">Test 1 (out of 25):</label>
    <input type="number" id="t1" name="t1" min="0" max="25" required><br><br>
    <label for="t2">Test 2 (out of 25):</label>
    <input type="number" id="t2" name="t2" min="0" max="25" required><br><br>
    <label for="t3">Test 3 (out of 25):</label>
    <input type="number" id="t3" name="t3" min="0" max="25" required><br><br>
    <label for="t4">Test 4 (out of 25):</label>
    <input type="number" id="t4" name="t4" min="0" max="25" required><br><br>
    <button type="submit">Submit Marks</button>
</form>